# DNS Server
DNS_PORT=53
DNS_WORKERS=auto
DNS_CACHE_SIZE=50000
DNS_CPU_LIMIT=2.0
DNS_MEM_LIMIT=512M
RESOLVER_MODE=forward
LOG_LEVEL=info

# GUI
GUI_PORT=3003
JWT_SECRET=change-me-in-production-please
